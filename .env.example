TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://agent.tinyfish.ai/v1
TINYFISH_SEARCH_URL=https://api.search.tinyfish.ai
TINYFISH_FETCH_URL=https://api.fetch.tinyfish.ai
TINYFISH_WEBHOOK_SECRET=

# Supabase powers passwordless email sign-in/sign-up and synced user sessions.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key. Required for scheduled opportunity sync writes and durable newsletter upserts.
SUPABASE_SERVICE_ROLE_KEY=

# Protects /api/cron/opportunity-sync in production and GitHub Actions.
CRON_SECRET=
FOUNDERREACH_BASE_URL=

# Resend is optional for newsletter confirmations and internal signup notices.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=FounderReach <updates@founderreach.app>
NEWSLETTER_NOTIFY_EMAIL=

# Optional: Logo.dev has a free tier. Without this, FounderReach falls back to public favicons.
NEXT_PUBLIC_LOGO_DEV_TOKEN=

# PostHog product analytics. Add the project token from PostHog project settings.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
